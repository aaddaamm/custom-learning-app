{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for the learning app.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    {
      "identifier": "sql:allow-load",
      "allow": [{ "db": "sqlite:learning.db" }]
    }
  ]
}
