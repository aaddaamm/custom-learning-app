{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Custom Learning App",
  "version": "0.1.0",
  "identifier": "com.aaddaamm.custom-learning-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Custom Learning App",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
